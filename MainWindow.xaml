<Window x:Class="TcxEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TCX Editor — Garmin" Height="780" Width="1060"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="ErrorRow" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Severity}" Value="Error">
                    <Setter Property="Background" Value="#FFDDDD"/>
                    <Setter Property="Foreground" Value="#990000"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="Warning">
                    <Setter Property="Background" Value="#FFF8DC"/>
                    <Setter Property="Foreground" Value="#7A5F00"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Click="New_Click" InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open..." Click="Open_Click" InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="_Save" Click="Save_Click" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _As..." Click="SaveAs_Click" InputGestureText="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem x:Name="UndoMenuItem" Header="_Undo" Click="Undo_Click"
                          InputGestureText="Ctrl+Z" IsEnabled="False"/>
                <MenuItem x:Name="RedoMenuItem" Header="_Redo" Click="Redo_Click"
                          InputGestureText="Ctrl+Y" IsEnabled="False"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Validate" Click="Validate_Click" InputGestureText="F5"/>
                <Separator/>
                <MenuItem Header="Change Activity _Date..." Click="ChangeDate_Click"/>
                <MenuItem Header="Shift Activity _Time..." Click="ShiftTime_Click"/>
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock x:Name="StatusText" Text="Ready"/>
            <Separator/>
            <TextBlock x:Name="ValidationSummaryText"/>
        </StatusBar>

        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="80"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="*" MinHeight="80"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="Auto" MinHeight="32"/>
            </Grid.RowDefinitions>

            <!-- Activity info -->
            <GroupBox Grid.Row="0" Header="Activity" Padding="8" Margin="0,0,0,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Sport:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox Grid.Column="1" x:Name="SportCombo" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Start date:" VerticalAlignment="Center" Margin="12,0,6,0"/>
                    <DatePicker Grid.Column="3" x:Name="StartDatePicker" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="Time:" VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <TextBox Grid.Column="5" x:Name="StartTimePicker" VerticalAlignment="Center"
                             Width="90" HorizontalAlignment="Left" Margin="0,0,12,0"/>
                </Grid>
            </GroupBox>

            <!-- Laps toolbar -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,2">
                <TextBlock Text="Laps" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Content="Add" Click="AddLap_Click"/>
                <Button Content="Edit" Click="EditLap_Click"/>
                <Button Content="Delete" Click="DeleteLap_Click"/>
            </StackPanel>

            <!-- Laps grid -->
            <DataGrid Grid.Row="2" x:Name="LapsGrid" SelectionChanged="LapsGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Start" Binding="{Binding StartTime, StringFormat=\{0:yyyy-MM-dd HH:mm:ss\}}" Width="150"/>
                    <DataGridTextColumn Header="Duration" Binding="{Binding Duration}" Width="80"/>
                    <DataGridTextColumn Header="Distance (km)" Binding="{Binding DistanceKm}" Width="100"/>
                    <DataGridTextColumn Header="Max Speed (m/s)" Binding="{Binding MaximumSpeed, StringFormat=F2}" Width="120"/>
                    <DataGridTextColumn Header="Calories" Binding="{Binding Calories}" Width="70"/>
                    <DataGridTextColumn Header="Avg HR" Binding="{Binding AverageHeartRate}" Width="65"/>
                    <DataGridTextColumn Header="Max HR" Binding="{Binding MaximumHeartRate}" Width="65"/>
                    <DataGridTextColumn Header="Intensity" Binding="{Binding Intensity}" Width="90"/>
                    <DataGridTextColumn Header="Trackpoints" Binding="{Binding Trackpoints.Count}" Width="85"/>
                    <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Row="3" HorizontalAlignment="Stretch" Background="#DDD"/>

            <!-- Trackpoints panel -->
            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock x:Name="TrackpointsHeader" Text="Trackpoints" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Content="Add" Click="AddTrackpoint_Click"/>
                    <Button Content="Edit" Click="EditTrackpoint_Click"/>
                    <Button Content="Delete" Click="DeleteTrackpoint_Click"/>
                    <Button Content="Auto-distribute time" Click="AutoTime_Click"
                            ToolTip="Distribute timestamps proportionally based on each trackpoint's distance"/>
                </StackPanel>
                <DataGrid Grid.Row="1" x:Name="TrackpointsGrid">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Binding="{Binding Time, StringFormat=\{0:yyyy-MM-dd HH:mm:ss\}}" Width="150"/>
                        <DataGridTextColumn Header="Lat (°)" Binding="{Binding LatitudeDegrees, StringFormat=F6}" Width="90"/>
                        <DataGridTextColumn Header="Lon (°)" Binding="{Binding LongitudeDegrees, StringFormat=F6}" Width="90"/>
                        <DataGridTextColumn Header="Alt (m)" Binding="{Binding AltitudeMeters, StringFormat=F1}" Width="70"/>
                        <DataGridTextColumn Header="Distance (m)" Binding="{Binding DistanceMeters, StringFormat=F1}" Width="90"/>
                        <DataGridTextColumn Header="Heart Rate" Binding="{Binding HeartRateBpm}" Width="80"/>
                        <DataGridTextColumn Header="Cadence" Binding="{Binding Cadence}" Width="75"/>
                        <DataGridTextColumn Header="Speed (m/s)" Binding="{Binding Speed, StringFormat=F2}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <GridSplitter Grid.Row="5" HorizontalAlignment="Stretch" Background="#DDD"/>

            <!-- Validation panel -->
            <Expander Grid.Row="6" x:Name="ValidationExpander" Header="Validation" IsExpanded="False">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="80" MaxHeight="200"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,2,0,2">
                        <Button Content="Validate (F5)" Click="Validate_Click" Padding="8,3"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" x:Name="ValidationGrid"
                              IsReadOnly="True" RowStyle="{StaticResource ErrorRow}"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Type" Binding="{Binding SeverityLabel}" Width="90"/>
                            <DataGridTextColumn Header="Location" Binding="{Binding Context}" Width="260"/>
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Expander>
        </Grid>
    </DockPanel>
</Window>
