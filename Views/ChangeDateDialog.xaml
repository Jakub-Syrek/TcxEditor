<Window x:Class="TcxEditor.Views.ChangeDateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Activity Date" Width="400" Height="260" MinHeight="200" MinWidth="320"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,8,0">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,16"
                           Text="All timestamps (laps and trackpoints) will be shifted by the date difference. Times of day will remain unchanged."/>

                <TextBlock Text="Current date:" Margin="0,0,0,4"/>
                <TextBlock x:Name="CurrentDateText" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,16"/>

                <TextBlock Text="New date:" Margin="0,0,0,4"/>
                <DatePicker x:Name="NewDatePicker"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Click="Ok_Click"/>
            <Button Content="Cancel" Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
