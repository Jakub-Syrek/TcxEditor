<Window x:Class="TcxEditor.Views.LapDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Okrążenie" Width="420" Height="520" MinHeight="300" MinWidth="320"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel x:Name="Form" Margin="0,0,8,0">
            <TextBlock Text="Data i godzina startu:" Margin="0,0,0,2"/>
            <DatePicker x:Name="StartDate" Margin="0,0,0,8"/>

            <TextBlock Text="Godzina startu (HH:mm:ss):" Margin="0,0,0,2"/>
            <TextBox x:Name="StartTime" Margin="0,0,0,8"/>

            <TextBlock Text="Czas całkowity (sekundy):" Margin="0,0,0,2"/>
            <TextBox x:Name="TotalTime" Margin="0,0,0,8"/>

            <TextBlock Text="Dystans (metry):" Margin="0,0,0,2"/>
            <TextBox x:Name="Distance" Margin="0,0,0,8"/>

            <TextBlock Text="Maks. prędkość (m/s):" Margin="0,0,0,2"/>
            <TextBox x:Name="MaxSpeed" Margin="0,0,0,8"/>

            <TextBlock Text="Kalorie:" Margin="0,0,0,2"/>
            <TextBox x:Name="Calories" Margin="0,0,0,8"/>

            <TextBlock Text="Śr. tętno (bpm):" Margin="0,0,0,2"/>
            <TextBox x:Name="AvgHr" Margin="0,0,0,8"/>

            <TextBlock Text="Maks. tętno (bpm):" Margin="0,0,0,2"/>
            <TextBox x:Name="MaxHr" Margin="0,0,0,8"/>

            <TextBlock Text="Intensywność:" Margin="0,0,0,2"/>
            <ComboBox x:Name="Intensity" Margin="0,0,0,8"/>

            <TextBlock Text="Notatki:" Margin="0,0,0,2"/>
            <TextBox x:Name="Notes" Margin="0,0,0,8"/>
        </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="OK" Width="80" Click="Ok_Click"/>
            <Button Content="Anuluj" Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
