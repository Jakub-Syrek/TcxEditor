<Window x:Class="TcxEditor.Views.ShiftTimeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shift Activity Time" Width="420" Height="280" MinHeight="220" MinWidth="340"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,8,0">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,16"
                           Text="Shifts all timestamps (activity, laps, trackpoints) by the given amount. Use negative numbers to shift backwards."/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Hours:" VerticalAlignment="Center" Margin="0,0,6,4"/>
                    <TextBox  Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" x:Name="Hours" Text="0" Margin="0,0,8,0"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Minutes:" VerticalAlignment="Center" Margin="0,0,6,4"/>
                    <TextBox  Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" x:Name="Minutes" Text="0" Margin="0,0,8,0"/>
                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Seconds:" VerticalAlignment="Center" Margin="0,0,6,4"/>
                    <TextBox  Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="2" x:Name="Seconds" Text="0"/>
                </Grid>

                <TextBlock x:Name="PreviewText" Foreground="#555" FontStyle="Italic" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Click="Ok_Click"/>
            <Button Content="Cancel" Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
