<Window x:Class="TcxEditor.Views.TrackpointDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Punkt trasy" Width="400" Height="480" MinHeight="300" MinWidth="320"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,8,0">
            <TextBlock Text="Czas (RRRR-MM-DD HH:mm:ss):" Margin="0,0,0,2"/>
            <TextBox x:Name="Time" Margin="0,0,0,8"/>

            <TextBlock Text="Szerokość geograficzna (°):" Margin="0,0,0,2"/>
            <TextBox x:Name="Lat" Margin="0,0,0,8"/>

            <TextBlock Text="Długość geograficzna (°):" Margin="0,0,0,2"/>
            <TextBox x:Name="Lon" Margin="0,0,0,8"/>

            <TextBlock Text="Wysokość (m n.p.m.):" Margin="0,0,0,2"/>
            <TextBox x:Name="Altitude" Margin="0,0,0,8"/>

            <TextBlock Text="Dystans od startu (m):" Margin="0,0,0,2"/>
            <TextBox x:Name="Distance" Margin="0,0,0,8"/>

            <TextBlock Text="Tętno (bpm):" Margin="0,0,0,2"/>
            <TextBox x:Name="HeartRate" Margin="0,0,0,8"/>

            <TextBlock Text="Kadencja (rpm):" Margin="0,0,0,2"/>
            <TextBox x:Name="Cadence" Margin="0,0,0,8"/>

            <TextBlock Text="Prędkość (m/s):" Margin="0,0,0,2"/>
            <TextBox x:Name="Speed" Margin="0,0,0,8"/>
        </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="OK" Width="80" Click="Ok_Click"/>
            <Button Content="Anuluj" Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
